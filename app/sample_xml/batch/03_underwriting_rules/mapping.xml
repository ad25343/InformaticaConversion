    <TABLEATTRIBUTE NAME="Sql Query" VALUE="SELECT * FROM UNDERWRITING_GUIDELINES WHERE EFFECTIVE_DATE &lt;= TRUNC(SYSDATE) AND GUIDELINE_VERSION IN (SELECT MAX(GUIDELINE_VERSION) FROM UNDERWRITING_GUIDELINES WHERE EFFECTIVE_DATE &lt;= TRUNC(SYSDATE) GROUP BY LOAN_TYPE, OCCUPANCY_TYPE)"/>
