    <TRANSFORMFIELD DATATYPE="number" DEFAULTVALUE="" EXPRESSION="" EXPRESSIONTYPE="GENERAL" NAME="MAX_DTI_PCT" PORTTYPE="INPUT/OUTPUT" PRECISION="5" SCALE="2"/>
