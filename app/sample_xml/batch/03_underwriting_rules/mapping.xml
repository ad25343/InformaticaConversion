  <!-- TRANSFORMATION: EXP_UNDERWRITING_DECISION -->
  <TRANSFORMATION DESCRIPTION="Expression transformer for underwriting calculations" ISREUSUABLE="NO" NAME="EXP_UNDERWRITING_DECISION" OBJECTVERSION="1" REUSABLE="NO" TYPE="Expression" VERSIONNUMBER="1">
    <TRANSFORMFIELD DATATYPE="varchar" DEFAULTVALUE="" EXPRESSION="APPLICATION_ID" EXPRESSIONTYPE="GENERAL" NAME="APPLICATION_ID" PORTTYPE="INPUT/OUTPUT" PRECISION="50" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="number" DEFAULTVALUE="" EXPRESSION="LOAN_AMOUNT" EXPRESSIONTYPE="GENERAL" NAME="LOAN_AMOUNT" PORTTYPE="INPUT/OUTPUT" PRECISION="15" SCALE="2"/>
    <TRANSFORMFIELD DATATYPE="varchar" DEFAULTVALUE="" EXPRESSION="LOAN_TYPE" EXPRESSIONTYPE="GENERAL" NAME="LOAN_TYPE" PORTTYPE="INPUT/OUTPUT" PRECISION="20" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="varchar" DEFAULTVALUE="" EXPRESSION="OCCUPANCY_TYPE" EXPRESSIONTYPE="GENERAL" NAME="OCCUPANCY_TYPE" PORTTYPE="INPUT/OUTPUT" PRECISION="20" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="number" DEFAULTVALUE="" EXPRESSION="BUREAU_SCORE" EXPRESSIONTYPE="GENERAL" NAME="BUREAU_SCORE" PORTTYPE="INPUT/OUTPUT" PRECISION="4" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="varchar" DEFAULTVALUE="" EXPRESSION="CREDIT_TIER" EXPRESSIONTYPE="GENERAL" NAME="CREDIT_TIER" PORTTYPE="INPUT/OUTPUT" PRECISION="20" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="number" DEFAULTVALUE="" EXPRESSION="ANNUAL_INCOME" EXPRESSIONTYPE="GENERAL" NAME="ANNUAL_INCOME" PORTTYPE="INPUT/OUTPUT" PRECISION="15" SCALE="2"/>
    <TRANSFORMFIELD DATATYPE="number" DEFAULTVALUE="" EXPRESSION="MONTHLY_DEBT_PAYMENT" EXPRESSIONTYPE="GENERAL" NAME="MONTHLY_DEBT_PAYMENT" PORTTYPE="INPUT/OUTPUT" PRECISION="15" SCALE="2"/>
    <TRANSFORMFIELD DATATYPE="number" DEFAULTVALUE="" EXPRESSION="INTEREST_RATE" EXPRESSIONTYPE="GENERAL" NAME="INTEREST_RATE" PORTTYPE="INPUT/OUTPUT" PRECISION="5" SCALE="3"/>
    <TRANSFORMFIELD DATATYPE="number" DEFAULTVALUE="" EXPRESSION="LOAN_TERM_MONTHS" EXPRESSIONTYPE="GENERAL" NAME="LOAN_TERM_MONTHS" PORTTYPE="INPUT/OUTPUT" PRECISION="5" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="number" DEFAULTVALUE="" EXPRESSION="APPRAISED_VALUE" EXPRESSIONTYPE="GENERAL" NAME="APPRAISED_VALUE" PORTTYPE="INPUT/OUTPUT" PRECISION="15" SCALE="2"/>
    <TRANSFORMFIELD DATATYPE="number" DEFAULTVALUE="" EXPRESSION="MAX_LTV_PCT" EXPRESSIONTYPE="GENERAL" NAME="MAX_LTV_PCT" PORTTYPE="INPUT/OUTPUT" PRECISION="5" SCALE="2"/>
    <TRANSFORMFIELD DATATYPE="number" DEFAULTVALUE="" EXPRESSION="MAX_DTI_PCT" EXPRESSIONTYPE="GENERAL" NAME="MAX_DTI_PCT" PORTTYPE="INPUT/OUTPUT" PRECISION="5" SCALE="2"/>
    <TRANSFORMFIELD DATATYPE="number" DEFAULTVALUE="" EXPRESSION="MIN_CREDIT_SCORE" EXPRESSIONTYPE="GENERAL" NAME="MIN_CREDIT_SCORE" PORTTYPE="INPUT/OUTPUT" PRECISION="4" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="number" DEFAULTVALUE="" EXPRESSION="REQUIRES_PMI_ABOVE_LTV" EXPRESSIONTYPE="GENERAL" NAME="REQUIRES_PMI_ABOVE_LTV" PORTTYPE="INPUT/OUTPUT" PRECISION="5" SCALE="2"/>
    <TRANSFORMFIELD DATATYPE="number" DEFAULTVALUE="" EXPRESSION="IIF(ISNULL(APPRAISED_VALUE) OR APPRAISED_VALUE = 0, NULL, ROUND((LOAN_AMOUNT / APPRAISED_VALUE) * 100, 2))" EXPRESSIONTYPE="GENERAL" NAME="ACTUAL_LTV" PORTTYPE="OUTPUT" PRECISION="5" SCALE="2"/>
    <TRANSFORMFIELD DATATYPE="number" DEFAULTVALUE="" EXPRESSION="IIF(INTEREST_RATE = 0 OR LOAN_TERM_MONTHS = 0, LOAN_AMOUNT / LOAN_TERM_MONTHS, ROUND(LOAN_AMOUNT * (INTEREST_RATE / 1200) / (1 - POWER(1 + (INTEREST_RATE / 1200), -LOAN_TERM_MONTHS)), 2))" EXPRESSIONTYPE="GENERAL" NAME="MONTHLY_PAYMENT" PORTTYPE="OUTPUT" PRECISION="15" SCALE="2"/>
    <TRANSFORMFIELD DATATYPE="number" DEFAULTVALUE="" EXPRESSION="IIF(ANNUAL_INCOME = 0, NULL, ROUND(((MONTHLY_DEBT_PAYMENT + MONTHLY_PAYMENT) / (ANNUAL_INCOME / 12)) * 100, 2))" EXPRESSIONTYPE="GENERAL" NAME="DTI_RATIO" PORTTYPE="OUTPUT" PRECISION="5" SCALE="2"/>
    <TRANSFORMFIELD DATATYPE="varchar" DEFAULTVALUE="" EXPRESSION="IIF(ISNULL(ACTUAL_LTV) OR ISNULL(REQUIRES_PMI_ABOVE_LTV), 'U', IIF(ACTUAL_LTV > REQUIRES_PMI_ABOVE_LTV, 'Y', 'N'))" EXPRESSIONTYPE="GENERAL" NAME="REQUIRES_PMI" PORTTYPE="OUTPUT" PRECISION="1" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="varchar" DEFAULTVALUE="" EXPRESSION="IIF(ISNULL(ACTUAL_LTV) OR ISNULL(MAX_LTV_PCT), 'U', IIF(ACTUAL_LTV <= MAX_LTV_PCT, 'Y', 'N'))" EXPRESSIONTYPE="GENERAL" NAME="LTV_PASS" PORTTYPE="OUTPUT" PRECISION="1" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="varchar" DEFAULTVALUE="" EXPRESSION="IIF(ISNULL(DTI_RATIO), 'U', IIF(DTI_RATIO <= MAX_DTI_PCT, 'Y', 'N'))" EXPRESSIONTYPE="GENERAL" NAME="DTI_PASS" PORTTYPE="OUTPUT" PRECISION="1" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="varchar" DEFAULTVALUE="" EXPRESSION="IIF(ISNULL(BUREAU_SCORE) OR ISNULL(MIN_CREDIT_SCORE), 'U', IIF(BUREAU_SCORE >= MIN_CREDIT_SCORE, 'Y', 'N'))" EXPRESSIONTYPE="GENERAL" NAME="CREDIT_PASS" PORTTYPE="OUTPUT" PRECISION="1" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="varchar" DEFAULTVALUE="" EXPRESSION="IIF(BANKRUPTCY_FLAG = 'Y', 'N', 'Y')" EXPRESSIONTYPE="GENERAL" NAME="BANKRUPTCY_PASS" PORTTYPE="OUTPUT" PRECISION="1" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="varchar" DEFAULTVALUE="" EXPRESSION="IIF(FORECLOSURE_FLAG = 'Y', 'N', 'Y')" EXPRESSIONTYPE="GENERAL" NAME="FORECLOSURE_PASS" PORTTYPE="OUTPUT" PRECISION="1" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="varchar" DEFAULTVALUE="" EXPRESSION="CONCAT(IIF(LTV_PASS = 'N', 'LTV_EXCEED|', ''), IIF(DTI_PASS = 'N', 'DTI_EXCEED|', ''), IIF(CREDIT_PASS = 'N', 'CREDIT_LOW|', ''), IIF(BANKRUPTCY_PASS = 'N', 'BANKRUPTCY|', ''), IIF(FORECLOSURE_PASS = 'N', 'FORECLOSURE|', ''))" EXPRESSIONTYPE="GENERAL" NAME="DECISION_REASON" PORTTYPE="OUTPUT" PRECISION="500" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="date" DEFAULTVALUE="" EXPRESSION="GETDATE()" EXPRESSIONTYPE="GENERAL" NAME="UNDERWRITING_DATE" PORTTYPE="OUTPUT" PRECISION="10" SCALE="0"/>
  </TRANSFORMATION>

