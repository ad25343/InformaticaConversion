    <TRANSFORMFIELD DATATYPE="number" DEFAULTVALUE="" EXPRESSION="" EXPRESSIONTYPE="GENERAL" NAME="MAX_LOAN_AMOUNT" PORTTYPE="INPUT/OUTPUT" PRECISION="15" SCALE="2"/>
    <TRANSFORMFIELD DATATYPE="number" DEFAULTVALUE="" EXPRESSION="" EXPRESSIONTYPE="GENERAL" NAME="REQUIRES_PMI_ABOVE_LTV" PORTTYPE="INPUT/OUTPUT" PRECISION="5" SCALE="2"/>
