    <TRANSFORMFIELD DATATYPE="varchar" DEFAULTVALUE="" EXPRESSION="IIF(LOAN_STATUS = 'FUNDED', '1', IIF(LOAN_STATUS = 'APPROVED', '2', IIF(LOAN_STATUS = 'DECLINED', '3', IIF(LOAN_STATUS = 'CANCELLED', '4', '5'))))" EXPRESSIONTYPE="GENERAL" NAME="HMDA_ACTION_TYPE" PORTTYPE="OUTPUT" PRECISION="1" SCALE="0"/>
