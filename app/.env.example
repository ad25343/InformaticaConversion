# Informatica Conversion Tool — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Required ──────────────────────────────────────────────────────────────────
# Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Shared login password for the web UI.
# All personas use this same password — persona selection controls identity, not auth.
# Example: APP_PASSWORD=my-secure-passphrase-2026
APP_PASSWORD=your_app_password_here

# Secret key for session signing — use a long random string
SECRET_KEY=your_secret_key_here

# Session lifetime in hours (default: 8)
# SESSION_HOURS=8

# bcrypt work factor for password hashing — higher = slower brute-force (default: 12 ≈ 250ms)
# BCRYPT_ROUNDS=12

# ── Optional ──────────────────────────────────────────────────────────────────
# Override the Claude model (default: claude-sonnet-4-5-20250929)
# CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Server binding (defaults shown)
# HOST=0.0.0.0
# PORT=8000

# Logging verbosity: DEBUG | INFO | WARNING | ERROR (default: INFO)
# LOG_LEVEL=INFO

# Set to true to enable /docs (Swagger UI). Keep false in production.
# SHOW_DOCS=false

# CORS — comma-separated list of allowed origins. Leave unset for same-origin only.
# Example for a remote deployment:
# CORS_ORIGINS=https://mycompany.internal,https://datateam.mycompany.com

# Enable secure cookie flag (set to true when serving over HTTPS)
# HTTPS=false

# ── Upload size limits (security hardening) ────────────────────────────────────
# Maximum size for any single uploaded file (default 50 MB)
# MAX_UPLOAD_MB=50

# Maximum total extracted size from a ZIP upload — prevents zip bombs (default 200 MB)
# MAX_ZIP_EXTRACTED_MB=200

# Maximum number of files inside a ZIP upload (default 200)
# MAX_ZIP_FILE_COUNT=200

# Maximum number of mapping pipelines that run concurrently in a batch upload (default 3)
# Lower to reduce Claude API pressure; raise only if your API tier supports higher throughput
# BATCH_CONCURRENCY=3

# ── Database ───────────────────────────────────────────────────────────────────
# Path to the SQLite database file.
# Leave empty to use the default (app/data/jobs.db relative to repo root).
# Set to an absolute path for Docker or shared-filesystem deployments.
# DB_PATH=/data/jobs.db

# How long to keep completed jobs before the cleanup loop deletes them (default: 30 days)
# JOB_RETENTION_DAYS=30

# How often the cleanup loop runs (default: every 24 hours)
# CLEANUP_INTERVAL_HOURS=24

# ── Job export (disk write) ────────────────────────────────────────────────────
# Directory where completed job artifacts are written after Gate 3 approval.
# Defaults to <repo_root>/jobs if left empty.
# Set to an absolute path for Docker or CI deployments.
# Set to "disabled" to suppress disk writes entirely.
# OUTPUT_DIR=/output/jobs

# ── Rate limiting / reverse proxy (security) ──────────────────────────────────
# Number of trusted reverse proxies in front of this app (nginx, CloudFlare, load balancer).
# When > 0 the rate limiter reads the real client IP from the X-Forwarded-For header,
# skipping the last N entries (the trusted proxy hops) to get the actual client IP.
# Leave at 0 (default) when the app is exposed directly without a proxy — otherwise
# an attacker could spoof X-Forwarded-For to bypass rate limiting.
# Example: TRUSTED_PROXY_COUNT=1  (one nginx in front)
# TRUSTED_PROXY_COUNT=0

# Per-IP rate limits — format: "<count>/<unit>" where unit is second|minute|hour|day
# RATE_LIMIT_JOBS=20/minute
# RATE_LIMIT_LOGIN=5/minute

# ── GitHub PR integration (v2.10.0) ───────────────────────────────────────────
# When both GITHUB_TOKEN and GITHUB_REPO are set, the tool automatically opens
# a draft pull request after every Gate 3 approval.  Leave either unset to disable.
#
# GITHUB_TOKEN — Personal Access Token with "repo" scope, or a GitHub App token.
# Generate at: https://github.com/settings/tokens (classic) → repo ✓
# For GitHub Enterprise, use your instance URL when generating the token.
# GITHUB_TOKEN=ghp_...

# GITHUB_REPO — "owner/repo" format (e.g. "myorg/data-migration")
# GITHUB_REPO=myorg/data-migration

# Branch the generated PR targets (default: main)
# GITHUB_BASE_BRANCH=main

# GitHub Enterprise Server — override the API base URL.
# Standard GitHub Enterprise path includes /api/v3:
# GITHUB_API_URL=https://github.mycompany.com/api/v3

# ── Webhook notifications (v2.9.0) ────────────────────────────────────────────
# URL that receives a JSON POST at gate pauses, job completion, and hard failures.
# Leave unset (or empty) to disable all outbound notifications.
# Works with Slack incoming webhooks, Teams incoming webhooks, PagerDuty, or any
# HTTP endpoint that accepts a JSON POST.
#
# Examples:
#   Slack:  WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
#   Teams:  WEBHOOK_URL=https://myorg.webhook.office.com/webhookb2/...
#   Custom: WEBHOOK_URL=https://internal-alerts.mycompany.com/informatica
# WEBHOOK_URL=

# Optional HMAC-SHA256 signing key.
# When set, every outbound request includes:
#   X-Webhook-Signature: sha256=<hex>
# Your receiver computes HMAC-SHA256(WEBHOOK_SECRET, raw_body) and compares
# with constant-time equality to verify the payload came from this tool.
# Generate a key with: python -c "import secrets; print(secrets.token_hex(32))"
# WEBHOOK_SECRET=

# Per-request timeout for outbound webhook POSTs in seconds (default 10).
# WEBHOOK_TIMEOUT_SECS=10

# ── File watcher / scheduled ingestion (v2.14.1) ─────────────────────────────
# When WATCHER_ENABLED=true the app polls WATCHER_DIR for *.manifest.json files.
# Each manifest groups all related Informatica files for a project and triggers
# an automatic batch conversion — one job per mapping XML.
#
# MANIFEST FORMAT — drop a file named <anything>.manifest.json in WATCHER_DIR:
#   {
#     "version":  "1.0",
#     "label":    "Customer Data Pipeline — Q1 2026",  <-- optional but recommended
#                                                           drives output folder name
#     "mappings": [                   <-- required: one or more mapping XMLs
#       "m_customer_load.xml",        <-- string: inherits top-level workflow/params
#       "m_product_load.xml",
#       {                             <-- object: per-mapping overrides
#         "mapping":    "m_appraisal_rank.xml",
#         "workflow":   "wf_appraisal.xml",     <-- overrides top-level for this mapping
#         "parameters": "params_appraisal.xml"  <-- overrides top-level for this mapping
#       }
#     ],
#     "workflow":      "wf_default.xml",   <-- optional: default for all mappings
#     "parameters":    "params_prod.xml",  <-- optional: default for all mappings
#     "reviewer":      "Jane Smith",       <-- optional
#     "reviewer_role": "Data Engineer"     <-- optional
#   }
#
# OUTPUT DIRECTORY — artifacts are written to:
#   OUTPUT_DIR/<label>_<YYYYMMDD_HHMMSS_ffffff>/<mapping_stem>/
#   e.g. OUTPUT_DIR/Customer_Data_Pipeline_Q1_2026_20260305_143052_123456/m_customer_load/
# Timestamp always appended (microseconds) so re-runs never overwrite prior output.
#
# All referenced files must be in the same directory as the manifest.
# Drop the manifest LAST — it signals that all files are ready.
# Processed manifests → WATCHER_DIR/processed/
# Failed/incomplete manifests → WATCHER_DIR/failed/ with .error sidecar
#
# The UI updates automatically. Gate reviews still require human action.
#
# WATCHER_ENABLED=false
# WATCHER_DIR=/path/to/watch/folder
# WATCHER_POLL_INTERVAL_SECS=30
# WATCHER_INCOMPLETE_TTL_SECS=300

# ── Time-based scheduler (v2.15.0) ────────────────────────────────────────────
# When SCHEDULER_ENABLED=true the app polls SCHEDULER_DIR for *.schedule.json
# files and materialises *.manifest.json files into WATCHER_DIR when their cron
# expressions fire.  The manifest watcher (above) then processes them normally.
#
# WATCHER_ENABLED, WATCHER_DIR, and WATCHER_POLL_INTERVAL_SECS must also be set.
#
# SCHEDULE FILE FORMAT — drop a file named <anything>.schedule.json in SCHEDULER_DIR:
#   {
#     "version":  "1.0",
#     "cron":     "0 2 * * 1-5",              <-- required — 5-field cron expression
#     "timezone": "America/New_York",          <-- optional — IANA tz (default UTC)
#     "label":    "Customer Pipeline Nightly", <-- optional — output folder name
#     "enabled":  true,                        <-- optional — set false to pause
#     "manifest": {                            <-- required — manifest payload
#       "version":  "1.0",
#       "mappings": [
#         "m_customer_load.xml",
#         {
#           "mapping":  "m_appraisal_rank.xml",  <-- per-mapping override
#           "workflow": "wf_appraisal.xml"
#         }
#       ],
#       "workflow":      "wf_default.xml",
#       "parameters":    "params_prod.xml",
#       "reviewer":      "Jane Smith",
#       "reviewer_role": "Data Engineer"
#     }
#   }
#
# CRON FIELDS: minute  hour  day-of-month  month  day-of-week (0=Sun,1=Mon…6=Sat)
#   "0 2 * * 1-5"   weekdays at 02:00
#   "30 6 * * *"    every day at 06:30
#   "0 */4 * * *"   every 4 hours on the hour
#   "15 8 1 * *"    1st of every month at 08:15
#
# SCHEDULER_DIR is separate from WATCHER_DIR — schedule files live there;
# materialised manifests are written into WATCHER_DIR automatically.
# Schedule files are re-read on every poll — edits take effect immediately.
#
# SCHEDULER_ENABLED=false
# SCHEDULER_DIR=/path/to/schedules/folder
# SCHEDULER_POLL_INTERVAL_SECS=60

# ── Agent tuning ──────────────────────────────────────────────────────────────
# Hard timeout in seconds for the verification Claude call (default: 300)
# VERIFY_TIMEOUT_SECS=300

# Hard timeout in seconds applied to every Claude API call across all agents (default: 300)
# Increase if large mappings cause pipeline timeouts; decrease to fail fast.
# AGENT_TIMEOUT_SECS=300

# Anthropic beta header enabling extended output for the documentation agent.
# Update this value when Anthropic promotes a newer extended-output beta.
# EXTENDED_OUTPUT_BETA=output-128k-2025-02-19

# ── Enterprise AI Gateway (optional) ─────────────────────────────────────────
# Set USE_API_GATEWAY=true to route all Claude calls through your enterprise
# API gateway (Bedrock, Apigee, Azure APIM, etc.) instead of the Anthropic
# API directly.  ANTHROPIC_API_KEY is not required when this is enabled.
#
# When USE_API_GATEWAY=false (default) every setting below is ignored and
# the existing code path runs completely unchanged.
#
# USE_API_GATEWAY=false

# Full inference endpoint URL of the gateway.
# AI_GW_URL=https://your-gateway.internal/v1/chat/completions

# Static API key sent as the x-api-key header on every request.
# AI_KEY=your_gateway_api_key

# OAuth2 client-credentials grant — leave both empty to skip token fetch.
# When set, the client fetches a bearer token and adds Authorization: Bearer <token>.
# CLIENT_ID=your_client_id
# CLIENT_SECRET=your_client_secret

# Model identifier sent inside the gateway request body.
# May differ from CLAUDE_MODEL (e.g. a Bedrock ARN or an Apigee model alias).
# MODEL_ID=anthropic.claude-sonnet-4-5-20250929-v1:0

# Number of retry attempts for gateway calls (default: 3).
# NO_OF_RETRIES=3

# Log full request/response for debugging — do NOT enable in production.
# ENABLE_TRACE=false

# ── Testing only ──────────────────────────────────────────────────────────────
# Forces documentation_agent to use this token limit regardless of complexity tier.
# Set to a low value (e.g. 4096) to deliberately trigger DOCUMENTATION_TRUNCATED.
# Remove or comment out this line to restore tier-aware limits (up to 32 768 for VERY_HIGH).
# DOC_MAX_TOKENS_OVERRIDE=4096
