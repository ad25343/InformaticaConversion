<REPOSITORY CODEPAGE="UTF-8" DATABASETYPE="Oracle" NAME="FIRSTBANK_DWH" VERSION="112">
<FOLDER DESCRIPTION="Shared reusable mapplets" GROUP="" NAME="Shared_Mapplets" OWNER="Administrator" PERMISSIONS="rwx---r--" SHARED="SHARED">
  <MAPPLET DESCRIPTION="Shared audit stamp - generates ETL_LOAD_DT, ETL_UPDATE_DT, ETL_BATCH_ID, SOURCE_SYSTEM" ISVALID="YES" NAME="MPLT_AUDIT_STAMP" OBJECTVERSION="1" VERSIONNUMBER="1">
    <TRANSFORMATION DESCRIPTION="Audit column generator" ISREUSABLE="YES" NAME="EXP_AUDIT_STAMP" OBJECTVERSION="1" REUSABLE="YES" TYPE="Expression" VERSIONNUMBER="1">
      <TRANSFORMFIELD DATATYPE="date" DEFAULTVALUE="" DESCRIPTION="" EXPRESSION="SYSDATE" EXPRESSIONTYPE="GENERAL" NAME="o_ETL_LOAD_DT" PICTURETEXT="" PORTTYPE="OUTPUT" PRECISION="29" SCALE="9"/>
      <TRANSFORMFIELD DATATYPE="date" DEFAULTVALUE="" DESCRIPTION="" EXPRESSION="SYSDATE" EXPRESSIONTYPE="GENERAL" NAME="o_ETL_UPDATE_DT" PICTURETEXT="" PORTTYPE="OUTPUT" PRECISION="29" SCALE="9"/>
      <TRANSFORMFIELD DATATYPE="number" DEFAULTVALUE="" DESCRIPTION="" EXPRESSION="$$ETL_BATCH_ID" EXPRESSIONTYPE="GENERAL" NAME="o_ETL_BATCH_ID" PICTURETEXT="" PORTTYPE="OUTPUT" PRECISION="10" SCALE="0"/>
      <TRANSFORMFIELD DATATYPE="varchar" DEFAULTVALUE="" DESCRIPTION="" EXPRESSION="$$SOURCE_SYSTEM" EXPRESSIONTYPE="GENERAL" NAME="o_SOURCE_SYSTEM" PICTURETEXT="" PORTTYPE="OUTPUT" PRECISION="30" SCALE="0"/>
    </TRANSFORMATION>
    <INSTANCE NAME="EXP_AUDIT_STAMP" REUSABLE="YES" TRANSFORMATION_NAME="EXP_AUDIT_STAMP" TRANSFORMATION_TYPE="Expression" TYPE="TRANSFORMATION"/>
  </MAPPLET>
  <MAPPLET DESCRIPTION="Shared data cleansing - trim, upper, null handling" ISVALID="YES" NAME="MPLT_DATA_CLEANSING" OBJECTVERSION="1" VERSIONNUMBER="1">
    <TRANSFORMATION DESCRIPTION="Standard data cleansing rules" ISREUSABLE="YES" NAME="EXP_CLEANSE" OBJECTVERSION="1" REUSABLE="YES" TYPE="Expression" VERSIONNUMBER="1">
      <TRANSFORMFIELD DATATYPE="varchar" DEFAULTVALUE="" DESCRIPTION="" EXPRESSION="" EXPRESSIONTYPE="GENERAL" NAME="i_RAW_VALUE" PICTURETEXT="" PORTTYPE="INPUT" PRECISION="500" SCALE="0"/>
      <TRANSFORMFIELD DATATYPE="varchar" DEFAULTVALUE="" DESCRIPTION="" EXPRESSION="LTRIM(RTRIM(IIF(ISNULL(i_RAW_VALUE), &apos;&apos;, UPPER(REG_REPLACE(i_RAW_VALUE, &apos;[^A-Za-z0-9 _-]&apos;, &apos;&apos;)))))" EXPRESSIONTYPE="GENERAL" NAME="o_CLEAN_VALUE" PICTURETEXT="" PORTTYPE="OUTPUT" PRECISION="500" SCALE="0"/>
      <TRANSFORMFIELD DATATYPE="number" DEFAULTVALUE="" DESCRIPTION="" EXPRESSION="IIF(ISNULL(i_RAW_VALUE) OR LENGTH(LTRIM(RTRIM(i_RAW_VALUE))) = 0, 1, 0)" EXPRESSIONTYPE="GENERAL" NAME="o_IS_BLANK" PICTURETEXT="" PORTTYPE="OUTPUT" PRECISION="1" SCALE="0"/>
    </TRANSFORMATION>
    <INSTANCE NAME="EXP_CLEANSE" REUSABLE="YES" TRANSFORMATION_NAME="EXP_CLEANSE" TRANSFORMATION_TYPE="Expression" TYPE="TRANSFORMATION"/>
  </MAPPLET>
  <MAPPLET DESCRIPTION="Shared date dimension key lookup" ISVALID="YES" NAME="MPLT_DATE_DIMENSION_LOOKUP" OBJECTVERSION="1" VERSIONNUMBER="1">
    <TRANSFORMATION DESCRIPTION="Lookup date SK from DIM_DATE" ISREUSABLE="YES" NAME="LKP_DIM_DATE" OBJECTVERSION="1" REUSABLE="YES" TYPE="Lookup Procedure" VERSIONNUMBER="1">
      <TRANSFORMFIELD DATATYPE="date" DEFAULTVALUE="" DESCRIPTION="" EXPRESSION="" EXPRESSIONTYPE="GENERAL" NAME="i_BUSINESS_DATE" PICTURETEXT="" PORTTYPE="INPUT" PRECISION="29" SCALE="9"/>
      <TRANSFORMFIELD DATATYPE="number" DEFAULTVALUE="0" DESCRIPTION="" EXPRESSION="" EXPRESSIONTYPE="GENERAL" NAME="o_DATE_SK" PICTURETEXT="" PORTTYPE="OUTPUT" PRECISION="10" SCALE="0"/>
      <TRANSFORMFIELD DATATYPE="varchar" DEFAULTVALUE="" DESCRIPTION="" EXPRESSION="" EXPRESSIONTYPE="GENERAL" NAME="o_FISCAL_PERIOD" PICTURETEXT="" PORTTYPE="OUTPUT" PRECISION="10" SCALE="0"/>
      <TABLEATTRIBUTE NAME="Lookup table name" VALUE="DIM_DATE"/>
      <TABLEATTRIBUTE NAME="Lookup condition" VALUE="DIM_DATE.CALENDAR_DATE = i_BUSINESS_DATE"/>
      <TABLEATTRIBUTE NAME="Lookup Policy on Multiple Match" VALUE="Use First Value"/>
      <TABLEATTRIBUTE NAME="Lookup cache directory name" VALUE="$PMCacheDir"/>
      <TABLEATTRIBUTE NAME="Lookup cache persistent" VALUE="YES"/>
      <TABLEATTRIBUTE NAME="Lookup Cache Size" VALUE="5000000"/>
    </TRANSFORMATION>
    <INSTANCE NAME="LKP_DIM_DATE" REUSABLE="YES" TRANSFORMATION_NAME="LKP_DIM_DATE" TRANSFORMATION_TYPE="Lookup Procedure" TYPE="TRANSFORMATION"/>
  </MAPPLET>
  <MAPPLET DESCRIPTION="Account number masking for PII protection" ISVALID="YES" NAME="MPLT_ACCOUNT_NUMBER_MASK" OBJECTVERSION="1" VERSIONNUMBER="1">
    <TRANSFORMATION DESCRIPTION="Mask account number for non-prod" ISREUSABLE="YES" NAME="EXP_ACCT_MASK" OBJECTVERSION="1" REUSABLE="YES" TYPE="Expression" VERSIONNUMBER="1">
      <TRANSFORMFIELD DATATYPE="varchar" DEFAULTVALUE="" DESCRIPTION="" EXPRESSION="" EXPRESSIONTYPE="GENERAL" NAME="i_ACCOUNT_NUMBER" PICTURETEXT="" PORTTYPE="INPUT" PRECISION="20" SCALE="0"/>
      <TRANSFORMFIELD DATATYPE="varchar" DEFAULTVALUE="" DESCRIPTION="" EXPRESSION="IIF($$ENVIRONMENT = &apos;PROD&apos;, i_ACCOUNT_NUMBER, CONCAT(LPAD(&apos;&apos;, LENGTH(i_ACCOUNT_NUMBER) - 4, &apos;X&apos;), SUBSTR(i_ACCOUNT_NUMBER, LENGTH(i_ACCOUNT_NUMBER) - 3, 4)))" EXPRESSIONTYPE="GENERAL" NAME="o_MASKED_ACCOUNT" PICTURETEXT="" PORTTYPE="OUTPUT" PRECISION="20" SCALE="0"/>
    </TRANSFORMATION>
    <INSTANCE NAME="EXP_ACCT_MASK" REUSABLE="YES" TRANSFORMATION_NAME="EXP_ACCT_MASK" TRANSFORMATION_TYPE="Expression" TYPE="TRANSFORMATION"/>
  </MAPPLET>
</FOLDER>
